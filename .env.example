# ─── WebSocket Bridge ────────────────────────────────────────────────────────

# Host the bridge binds to. Keep 127.0.0.1 (loopback only — never expose to network).
WS_HOST=127.0.0.1

# Port the bridge listens on. Must match WS_URL in the MCP server.
WS_PORT=9001

# How long (ms) the MCP server waits for a response from the Figma plugin before
# timing out a tool call. 30s covers slow importComponentByKeyAsync calls.
WS_TIMEOUT_MS=30000

# Full WebSocket URL the MCP server connects to. Change port here if you changed WS_PORT.
WS_URL=ws://127.0.0.1:9001?role=mcp-client


# ─── Logging ─────────────────────────────────────────────────────────────────

# Minimum log level to emit.
# Values: trace | debug | info | warn | error | fatal | silent
# Use "debug" during development, "info" in production, "silent" in tests.
LOG_LEVEL=info

# Set to "true" to enable human-readable colored output (pino-pretty).
# Leave unset or "false" in production — JSON output is better for log aggregators.
LOG_PRETTY=false

# Absolute or relative path to write logs to a file.
# When set, logs are appended to this file instead of stderr.
# Useful for capturing MCP server logs that Cursor would otherwise discard.
# Example: LOG_FILE=logs/mcp.log
# Leave blank to log to stderr (default).
LOG_FILE=
