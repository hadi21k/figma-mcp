{
  "name": "figma-mcp",
  "version": "1.0.0",
  "description": "MCP server for generating and manipulating Figma designs via Claude",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:plugin": "node esbuild.plugin.mjs",
    "build:all": "npm run build && npm run build:plugin",
    "socket": "node dist/websocket-server/index.js",
    "mcp": "node dist/mcp-server/index.js",
    "dev:socket": "tsx watch src/websocket-server/index.ts",
    "dev:mcp": "tsx watch src/mcp-server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
