{
  "name": "figma-mcp",
  "version": "1.0.0",
  "description": "MCP server for generating and manipulating Figma designs via Claude",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:all": "npm run build",
    "socket": "node dist/websocket-server/index.js",
    "mcp": "node dist/mcp-server/index.js",
    "dev:socket": "tsx watch --env-file=.env src/websocket-server/index.ts",
    "dev:mcp": "tsx watch --env-file=.env src/mcp-server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/sharp": "^0.31.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
